# =========================================================================
#             ENTERPRISE JOB MOBILITY PLATFORM - ENVIRONMENT CONFIGS
# =========================================================================

# -------------------------------------------------------------------------
# BACKEND SERVICES CONFIGURATIONS (server.ts / server/)
# -------------------------------------------------------------------------
# Web Server host configuration variables
PORT=3000
NODE_ENV=production

# JWT encryption secret key for signing user sessions
JWT_SECRET=replace_with_a_long_random_secure_secret_hash_key_in_production

# Google Gemini Core AI API Key (Server-side exclusive, DO NOT PREFIX WITH VITE_)
GEMINI_API_KEY=AIzaSyD-REPLACE_WITH_YOUR_PRODUCTION_GEMINI_API_KEY

# Persistent Storage Path (Optional: defaults to database_store.json in root or /data/ on cloud providers)
DB_PATH=./database_store.json

# Resend API Key for Enterprise Email Logs / Sync notifications (Optional)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE


# -------------------------------------------------------------------------
# FRONTEND CONFIGURATIONS (Vite / React)
# -------------------------------------------------------------------------
# Base URL of your deployed backend rest API portal
# Note: Local dev defaults to empty since we proxy requests via Vite or relative paths
VITE_API_BASE_URL=http://localhost:3000

# -------------------------------------------------------------------------
# FIREBASE PROJECT CONFIGURATIONS (Client-side sync/SSO Setup)
# -------------------------------------------------------------------------
# These fields correspond to your firebase-applet-config.json settings.
# When pushing to Github, your Firebase auth configs can also be injected 
# via these standard Vite public environment prefixes:
VITE_FIREBASE_API_KEY=AIzaSy_YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-app-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-app-id
VITE_FIREBASE_STORAGE_BUCKET=your-app-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:00000:web:000000000
